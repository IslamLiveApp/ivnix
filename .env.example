# Public site URL (production: https://your-domain.com)
NEXT_PUBLIC_SITE_URL=

# Stripe — secret/restricted key from Dashboard → Developers → API keys
# Must match mode + account of STRIPE_PRICE_ID_MONTHLY:
#   Test checkout  → rk_test_... or sk_test_...  + test price_...
#   Real checkout  → rk_live_... or sk_live_...  + live price_...
# Real cards are rejected when the key is test mode (and vice versa).
STRIPE_SECRET_KEY=

# Recurring monthly membership price ID (test or live, same account as STRIPE_SECRET_KEY)
# One-time tips use dynamic `price_data`; no tip Price ID required.
STRIPE_PRICE_ID_MONTHLY=

# Stripe webhook signing secret — Dashboard → Developers → Webhooks → Signing secret (`whsec_...`)
# Local forwarding: stripe listen --forward-to localhost:3000/api/stripe/webhook
STRIPE_WEBHOOK_SECRET=

# After STRIPE_SECRET_KEY is set: npm run stripe:ensure-monthly
